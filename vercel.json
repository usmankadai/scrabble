{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "https://scrabble-ntna.onrender.com/",
      "permanent": false
    },
    {
      "source": "/:path*",
      "destination": "https://scrabble-ntna.onrender.com/:path*",
      "permanent": false
    }
  ]
}
